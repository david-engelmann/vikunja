{
  "uid": "vikunja-logs",
  "title": "Vikunja Logs",
  "tags": [
    "vikunja",
    "logs",
    "loki"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Stack Logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "expr": "{compose_project=\"vikunja\"}"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Vikunja App Logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "expr": "{compose_project=\"vikunja\", compose_service=\"vikunja\"}"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "sortOrder": "Descending"
      }
    }
  ]
}
